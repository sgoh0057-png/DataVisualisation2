{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "How sport participation changes with age",
    "subtitle": "Participation rate across major sports by age group",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "fontWeight": 700,
    "subtitleColor": "#6f6f6f",
    "color": "#111",
    "offset": 12
  },

  "data": {
    "url": "participation_age.csv"
  },

  "transform": [
    {
      "filter": "datum.Sport != null && datum.Sport != '' && datum.Age != null && datum.Age != '' && datum.Rate != null && datum.Rate != ''"
    },
    {
      "calculate": "toNumber(replace(datum.Rate, '%', '')) / 100",
      "as": "RateValue"
    }
  ],

  "width": "container",
  "height": 250,

  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 45
    },
    "strokeWidth": 2.5
  },

  "encoding": {
    "x": {
      "field": "Age",
      "type": "ordinal",
      "title": "Age group",
      "sort": ["15-17", "18-24", "25-34", "35-44", "45-54", "55-64", "65+"],
      "axis": {
        "labelFontSize": 11,
        "titleFontSize": 12,
        "labelColor": "#111",
        "titleColor": "#111",
        "labelAngle": -90,
        "ticks": false,
        "domain": false
      }
    },

    "y": {
      "field": "RateValue",
      "type": "quantitative",
      "title": "Participation rate",
      "axis": {
        "format": ".0%",
        "labelFontSize": 11,
        "titleFontSize": 12,
        "labelColor": "#555",
        "titleColor": "#555",
        "gridColor": "#e9e3da",
        "gridOpacity": 0.65,
        "tickColor": "#d8d1c8",
        "domainColor": "#d8d1c8"
      }
    },

    "color": {
  "field": "Sport",
  "type": "nominal",
  "scale": {
    "domain": [
      "Australian football",
      "Basketball",
      "Cricket",
      "Football/soccer",
      "Netball",
      "Tennis"
    ],
    "range": [
      "#4E79A7",
      "#F28E2B",
      "#E15759",
      "#76B7B2",
      "#59A14F",
      "#EDC948"
    ]
  },
  "legend": {
    "title": "Sport",
    "orient": "bottom",
    "columns": 3,
    "labelFontSize": 11,
    "titleFontSize": 12,
    "labelColor": "#555",
    "titleColor": "#111"
  }
},

    "tooltip": [
      {
        "field": "Sport",
        "type": "nominal"
      },
      {
        "field": "Age",
        "type": "nominal",
        "title": "Age group"
      },
      {
        "field": "RateValue",
        "type": "quantitative",
        "title": "Participation rate",
        "format": ".1%"
      }
    ]
  },

  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Arial"
  }
}
{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Volunteer participation by gender",
    "subtitle": "Male and female volunteer participation rates by sport",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "fontWeight": 700,
    "subtitleColor": "#6f6f6f",
    "color": "#111",
    "offset": 12
  },

  "data": {
    "url": "volunteer_gender.csv"
  },

  "transform": [
    {
      "fold": ["Males", "Females"],
      "as": ["Gender", "Rate"]
    },
    {
      "calculate": "toNumber(replace(datum.Rate, '%', '')) / 100",
      "as": "RateValue"
    }
  ],

  "width": "container",
  "height": 250,

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3,
    "height": 22
  },

  "encoding": {
    "y": {
      "field": "Sport",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "axis": {
        "labelFontSize": 12,
        "labelColor": "#111",
        "labelPadding": 8,
        "ticks": false,
        "domain": false
      }
    },

    "x": {
      "field": "RateValue",
      "type": "quantitative",
      "stack": true,
      "title": "Volunteer participation rate",
      "axis": {
        "format": ".0%",
        "labelFontSize": 11,
        "titleFontSize": 12,
        "labelColor": "#555",
        "titleColor": "#555",
        "gridColor": "#e9e3da",
        "gridOpacity": 0.65,
        "tickColor": "#d8d1c8",
        "domainColor": "#d8d1c8"
      }
    },

    "color": {
      "field": "Gender",
      "type": "nominal",
      "scale": {
        "domain": ["Males", "Females"],
        "range": ["#4E79A7", "#EF6F9F"]
      },
      "legend": {
        "title": null,
        "orient": "top",
        "labelFontSize": 11,
        "labelColor": "#555",
        "symbolSize": 90
      }
    },

    "tooltip": [
      {
        "field": "Sport",
        "type": "nominal"
      },
      {
        "field": "Gender",
        "type": "nominal"
      },
      {
        "field": "RateValue",
        "type": "quantitative",
        "title": "Volunteer rate",
        "format": ".1%"
      }
    ]
  },

  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "font": "Arial",
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}